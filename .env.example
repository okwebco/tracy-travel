# ============================================================
#  Tracy Travel — variables de entorno
#  Todo funciona en MODO DEMO sin credenciales (datos mock).
# ============================================================

# Modo de aplicación (opcional). Este repo es siempre Tracy.
APP_MODE=tracy

# Base de datos. Local: sqlite:///./tracy.db  ·  Cloud Run: sqlite:////data/tracy.db
DATABASE_URL=sqlite:///./tracy.db

# WhatsApp (Green API)
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
# Número emisor de Tracy (con código de país, solo dígitos)
WHATSAPP_SENDER=573126593121

# Clave de acceso a la landing pública de Tracy (default Tracy310, shell-safe)
LANDING_PASSWORD=Tracy310

# URL pública base para los enlaces a la página de reporte
PUBLIC_BASE_URL=https://tracy.okweb.co

# Token que protege los crons internos (header X-Cron-Token). En MODO DEMO puede ir vacío.
CRON_TOKEN=

# Proveedores activos (coma-separados). Si ninguno tiene credencial → mock (demo).
PROVEEDORES_VUELOS=travelpayouts,amadeus
PROVEEDORES_HOTELES=hotellook,amadeus

# Travelpayouts (opcional). Token: https://www.travelpayouts.com
TRAVELPAYOUTS_TOKEN=
# Marker de afiliado (se añade a los enlaces de reserva para ganar comisión)
TRAVELPAYOUTS_MARKER=734957

# Amadeus Self-Service (opcional). Si faltan, Amadeus se omite.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE=https://test.api.amadeus.com

# Moneda por defecto y vida de los reportes (horas)
MONEDA_DEFECTO=COP
REPORTE_TTL_HORAS=48
